# Local tool installations — large binaries, venvs, model weights
tools/
gfpgan/

# Input media and upscaled output — media files stay local, never committed
input/images/*
input/video/*
!input/images/.gitkeep
!input/video/.gitkeep
output/
results/
test-assets/output/

# Test assets — all media generated by scripts/download-test-media.sh, never committed.
# Directory structure preserved via .gitkeep; see test-assets/.gitignore for details.

# Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Model weight files
*.pth
*.onnx
*.safetensors

# Editor / OS
.DS_Store
*.swp
*~
