# Local tool installations — large binaries, venvs, model weights
tools/

# Input media and upscaled output — media files stay local, never committed
input/images/*
input/video/*
!input/images/.gitkeep
!input/video/.gitkeep
output/
results/
test-assets/output/

# Test assets — synthetic fixtures and SR benchmarks committed; real/large media ignored.
test-assets/images/*
!test-assets/images/test-image.png
!test-assets/images/test-tiny.png
# Set5 SR benchmark — LR inputs (bicubic ×4 downsamples, 128px wide)
!test-assets/images/baby.png
!test-assets/images/bird.png
!test-assets/images/butterfly.png
!test-assets/images/head.png
!test-assets/images/woman.png
# BSD100 SR benchmark — 5 diverse natural scenes (LR inputs)
!test-assets/images/bsd_101085.png
!test-assets/images/bsd_148026.png
!test-assets/images/bsd_21077.png
!test-assets/images/bsd_299086.png
!test-assets/images/bsd_45096.png
# Ground truth originals (HR) — kept alongside LR for quality comparison
!test-assets/images/gt/
test-assets/images/gt/*
!test-assets/images/gt/baby.png
!test-assets/images/gt/bird.png
!test-assets/images/gt/butterfly.png
!test-assets/images/gt/head.png
!test-assets/images/gt/woman.png
!test-assets/images/gt/bsd_101085.png
!test-assets/images/gt/bsd_148026.png
!test-assets/images/gt/bsd_21077.png
!test-assets/images/gt/bsd_299086.png
!test-assets/images/gt/bsd_45096.png
# Demo set — architecture, signage, degraded scan; LR inputs + GT originals
!test-assets/images/demo/
test-assets/images/demo/gt/*
!test-assets/images/demo/gt/budapest-parliament.jpg
!test-assets/images/demo/gt/76-ball-sign.jpg
!test-assets/images/demo/gt/nypl-1908-scan.jpg
test-assets/images/demo/*
!test-assets/images/demo/budapest-parliament-lr480.png
!test-assets/images/demo/budapest-parliament-854x480.png
!test-assets/images/demo/76-ball-sign-lr320.png
!test-assets/images/demo/nypl-1908-scan-lr480.png
test-assets/videos/*
!test-assets/videos/test-clip.mp4

